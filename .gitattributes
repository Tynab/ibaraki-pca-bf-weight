# Normalize text files while preserving binary assets.
* text=auto

# Keep Visual Studio/VB project files on CRLF to avoid local churn on Windows.
*.sln text eol=crlf
*.vb text eol=crlf
*.vbproj text eol=crlf
*.resx text eol=crlf
*.config text eol=crlf
*.settings text eol=crlf
*.myapp text eol=crlf
*.vdproj text eol=crlf

# Explicit binary rules (no line-ending conversion, no LFS filter).
*.bmp binary
*.png binary
*.ico binary
*.gif binary
